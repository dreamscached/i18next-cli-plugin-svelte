{
  "packageManager": "yarn@4.14.1",
  "name": "i18next-cli-plugin-svelte",
  "version": "2.2.0",
  "description": "i18next-cli plugin to extract Javascript/Typescript from Svelte components",
  "keywords": [
    "i18next",
    "i18next-cli",
    "i18n",
    "svelte",
    "estree-walker",
    "extract",
    "i18next-cli-plugin",
    "plugin"
  ],
  "author": {
    "name": "dreamscached",
    "email": "dreamscache.d@gmail.com",
    "url": "https://github.com/dreamscached"
  },
  "funding": {
    "type": "buymeacoffee",
    "url": "https://buymeacoffee.com/dreamscached"
  },
  "repository": {
    "url": "git+https://github.com/dreamscached/i18next-cli-plugin-svelte.git",
    "type": "git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run -v --coverage .",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "yarn build"
  },
  "type": "module",
  "exports": {
    "default": "./dist/index.js"
  },
  "files": [
    "./dist"
  ],
  "peerDependencies": {
    "estree-walker": "^3.0.3",
    "i18next-cli": "^1.51.6",
    "svelte": "^5.53.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.1.0",
    "estree-walker": "^3.0.3",
    "i18next": "^26.0.3",
    "i18next-cli": "^1.51.6",
    "prettier": "^3.8.1",
    "svelte": "^5.55.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
